NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_TMALL_STORE_URL=https://minvlang.tmall.com/
NEXT_PUBLIC_JD_STORE_URL=https://mall.jd.com/index-127854045.html?cid=0
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_BAIDU_TONGJI_ID=

# CMS admin authentication
# Local bypass only works with NODE_ENV != production and localhost/127.0.0.1 URLs.
CMS_ALLOW_LOCAL_ADMIN=false
CMS_LOCAL_ADMIN_EMAIL=local-admin@sweetmeilon.test
CMS_ENVIRONMENT=local
CF_ACCESS_AUDIENCE=REPLACE_WITH_ACCESS_AUDIENCE
CF_ACCESS_ISSUER=https://REPLACE_WITH_TEAM_NAME.cloudflareaccess.com
CMS_PUBLIC_D1_READS=false

# Import and SEO plugin
CMS_IMPORT_ENABLE=true
CMS_IMPORT_MAX_URLS_PER_BATCH=50
CMS_IMPORT_FETCH_TIMEOUT_MS=8000
CMS_IMPORT_USER_AGENT=SWEETMEILON-CMS-Importer/1.0
CMS_SEO_INDEXNOW_ENABLE=false
CMS_SEO_INDEXNOW_KEY=
CMS_SEO_AUTO_SUBMIT=false
CMS_AI_GENERATION_ENABLE=false
