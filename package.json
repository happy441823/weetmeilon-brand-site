{
  "name": "minvlang-brand-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "tsc --noEmit -p tsconfig.check.json",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cms:migrate:dev": "wrangler d1 migrations apply sweetmeilon-cms-dev --env preview --local",
    "cms:migrate:preview": "wrangler d1 migrations apply sweetmeilon-cms-dev --env preview --remote",
    "cms:seed": "node scripts/cms-seed-from-static.mjs",
    "cms:backup": "node scripts/cms-backup-local.mjs",
    "test": "node --test tests/cms/*.test.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "catalog:discover": "node scripts/discover-store-products.mjs",
    "catalog:normalize": "node scripts/normalize-products.mjs",
    "catalog:match": "node scripts/match-channel-products.mjs",
    "catalog:review": "node scripts/export-catalog-review.mjs",
    "catalog:import": "node scripts/import-catalog-products.mjs",
    "catalog:validate": "node scripts/validate-catalog.mjs",
    "catalog:check-images": "node scripts/check-product-images.mjs",
    "catalog:check-links": "node scripts/check-product-links.mjs",
    "catalog:sync": "npm run catalog:discover && npm run catalog:normalize && npm run catalog:match && npm run catalog:review && npm run catalog:validate"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.8.5",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "wrangler": "^4.68.0"
  }
}
